		{"id":"ddea2d2a52e5f4c0","type":"file","file":"Plot/Informations/Characters's information/Karoline “William.” Magdalena.md","x":12180,"y":4283,"width":400,"height":400},
		{"id":"571245d0d69e5f25","type":"text","text":"(1989 Tháng 6) Họ gặp được Karoline, Karoline được thêm vào sư đoàn của họ","x":12210,"y":3924,"width":340,"height":100},
		{"id":"3ba2454a964f6d46","type":"file","file":"Plot/Informations/Characters's information/Margarete “Steiner.” Iyoda.md","x":12660,"y":4283,"width":400,"height":400},
		{"id":"e144bfb3673fb30f","type":"text","text":"(1989 Tháng 7) Họ gặp được Margarete, Margarete được thêm vào sư đoàn của họ","x":12690,"y":3924,"width":340,"height":100},
