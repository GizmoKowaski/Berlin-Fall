		{"id":"0df3c60a0ef38336","type":"file","file":"Plot/Informations/Characters's information/Hans “Holtzmann.” Wegner.md","x":13620,"y":4283,"width":400,"height":400},
		{"id":"d1212218ac3c8433","type":"text","text":"(1989 Tháng 9) Họ gặp được Hans, Hans được thêm vào sư đoàn của họ","x":13650,"y":3924,"width":340,"height":100},
		{"id":"4bf23e0e5a88e84d","type":"file","file":"Plot/Informations/Characters's information/Frank “Becker.” Krämer.md","x":14080,"y":4283,"width":400,"height":400},
		{"id":"c712672d798eb052","type":"text","text":"(1989 Tháng 9) Họ gặp được Frank, Frank được thêm vào sư đoàn của họ","x":14110,"y":3924,"width":340,"height":100},
		{"id":"b1690dd10404c664","type":"file","file":"Plot/Informations/Characters's information/Oscar “Von.” Loiselle.md","x":11640,"y":4283,"width":400,"height":400},
		{"id":"7d1a286c65966320","type":"text","text":"(1989) Heimer và Dovid được gửi đi vào trại huấn luyện vào mỗi buổi sáng và cả ngày vào cuối tuần, cả 2 gặp được Oscar vào tháng 5, Oscar được thêm vào sư đoàn.","x":11670,"y":3877,"width":340,"height":194},
